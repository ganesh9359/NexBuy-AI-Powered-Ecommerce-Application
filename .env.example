# Backend
PORT=8080

# Database
# Convert the Aiven mysql:// URI to JDBC format for Spring Boot.
# Example:
# jdbc:mysql://mysql-host:23222/defaultdb?sslMode=REQUIRED
DB_URL=jdbc:mysql://mysql-6e7cef1-ganeshsuryawanshi9158-1cdb.j.aivencloud.com:23222/defaultdb?sslMode=REQUIRED
DB_USERNAME=<your-aiven-username>
DB_PASSWORD=<your-aiven-password>

# Security
JWT_SECRET=<base64-encoded-jwt-secret>

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false

# Email
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=<your-email>
SPRING_MAIL_PASSWORD=<your-app-password>
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# Frontend + CORS
APP_FRONTEND_URL=https://nex-buy-ai-powered-ecommerce-applic.vercel.app
APP_CORS_ALLOWED_ORIGINS=https://nex-buy-ai-powered-ecommerce-applic.vercel.app

# Uploads
APP_UPLOAD_DIR=uploads
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SSL_ENABLED=false
MANAGEMENT_HEALTH_REDIS_ENABLED=false
MANAGEMENT_HEALTH_ELASTICSEARCH_ENABLED=false

# Payments
APP_PAYMENT_RAZORPAY_KEY_ID=<your-razorpay-key-id>
APP_PAYMENT_RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
APP_PAYMENT_RAZORPAY_BASE_URL=https://api.razorpay.com
APP_PAYMENT_RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# AI
APP_AI_OPENAI_API_KEY=<your-openai-api-key>
APP_AI_OPENAI_BASE_URL=https://api.openai.com/v1
APP_AI_OPENAI_SEARCH_MODEL=gpt-4.1-mini
APP_AI_OPENAI_VISION_MODEL=gpt-4.1-mini

# Frontend runtime API target
# This is configured separately in frontend/src/assets/runtime-config.js
# apiBase=https://nexbuy-backend-8k6a.onrender.com
