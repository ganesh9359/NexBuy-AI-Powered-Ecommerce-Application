# ─────────────────────────────────────────────────────────────────────────────
# NexBuy — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/nexbuy_db
DB_USERNAME=nexbuy_user
DB_PASSWORD=your_strong_db_password_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_64_char_random_secret_here

# ── Email (Gmail App Password) ────────────────────────────────────────────────
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password_here

# ── CORS & Frontend ───────────────────────────────────────────────────────────
APP_FRONTEND_URL=https://your-domain.com
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Razorpay Payment ──────────────────────────────────────────────────────────
# Use rzp_live_* keys for production
APP_PAYMENT_RAZORPAY_KEY_ID=rzp_live_your_key_id
APP_PAYMENT_RAZORPAY_KEY_SECRET=your_razorpay_secret
APP_PAYMENT_RAZORPAY_BASE_URL=https://api.razorpay.com
APP_PAYMENT_RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SSL_ENABLED=false

# ── AI (Optional) ─────────────────────────────────────────────────────────────
APP_AI_OPENAI_API_KEY=sk-your_openai_key_here
APP_AI_OPENAI_BASE_URL=https://api.openai.com/v1
APP_AI_OPENAI_SEARCH_MODEL=gpt-4.1-mini
APP_AI_OPENAI_VISION_MODEL=gpt-4.1-mini

# ── File Uploads ──────────────────────────────────────────────────────────────
APP_UPLOAD_DIR=/var/nexbuy/uploads
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB
